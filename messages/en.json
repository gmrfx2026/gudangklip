  "CreatorRules": {
    "title": "FAQ & Rules",
    "subtitle": "Frequently asked questions and platform rules",
    "faq1q": "What is GudangKlip?",
    "faq1a": "GudangKlip is a video clipping platform connecting Brands with Clippers. Brands create campaigns, Clippers create short videos (TikTok, Instagram Reels, YouTube Shorts) for those campaigns and earn based on view counts.",
    "faq2q": "How do I earn money?",
    "faq2a": "1. Join available campaigns on the Campaigns page. 2. Read the campaign brief and materials. 3. Create videos according to the brief. 4. Submit videos through the campaign detail page. 5. Earn based on CPM (Cost Per 1000 Views) from every view of your videos.",
    "faq3q": "What is the minimum withdrawal?",
    "faq3a": "The minimum withdrawal is Rp 50,000. You can withdraw via Bank Transfer (BCA, BRI, Mandiri), GoPay, OVO, or DANA.",
    "faq4q": "Which platforms are supported?",
    "faq4a": "GudangKlip supports 3 platforms: TikTok, Instagram (Reels), and YouTube (Shorts). You can connect your social media accounts on the Profile page.",
    "faq5q": "How do I contact admin?",
    "faq5a": "You can contact admin via WhatsApp at the number listed in the sidebar or click the Contact Admin menu. Our team is ready to help!",
