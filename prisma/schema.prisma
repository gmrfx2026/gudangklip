generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BRAND
  CREATOR
  AGENCY
  ADMIN
}

enum Industry {
  E_COMMERCE
  FOOD_BEVERAGE
  FASHION_BEAUTY
  TECHNOLOGY
  FINANCE
  HEALTH_WELLNESS
  ENTERTAINMENT
  EDUCATION
  TRAVEL_HOSPITALITY
  OTHER
}

enum Platform {
  TIKTOK
  INSTAGRAM
  YOUTUBE
}

enum Category {
  MUSIC
  FILM
  BRAND
  ENTERTAINMENT
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ParticipantStatus {
  ACTIVE
  COMPLETED
  REMOVED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          Role      @default(CREATOR)
  companyName   String?
  industry      Industry?
  passwordHash  String?

  referralCode String?  @unique
  referredBy   String?
  referrer     User?    @relation("Referrals", fields: [referredBy], references: [id])
  referees     User[]   @relation("Referrals")

  walletBalance Float @default(0)
  trustScore    Int   @default(0)
  totalViews    Int   @default(0)
  totalEarnings Float @default(0)

  agencyId String?
  agency   Agency? @relation("AgencyMembers", fields: [agencyId], references: [id])

  socialAccounts  SocialAccount[]
  brandCampaigns  Campaign[]       @relation("Brand")
  participations  CampaignParticipant[]
  submissions     Submission[]
  payouts         Payout[]
  transactions    Transaction[]
  ownedAgency     Agency?          @relation("AgencyOwner")
  notifications   Notification[]
  sessions        Session[]
  accounts        Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SocialAccount {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform         Platform
  username         String
  verificationCode String?
  verified         Boolean  @default(false)
  followersCount   Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([userId, platform])
}

model Campaign {
  id              String         @id @default(cuid())
  brandId         String
  brand           User           @relation("Brand", fields: [brandId], references: [id])
  title           String
  description     String
  brief           String?
  category        Category
  totalBudget     Float
  remainingBudget Float
  cpmRate         Float
  minViewsToClaim Int            @default(1000)
  maxViewsPerVideo Int?
  startDate       DateTime
  endDate         DateTime
  status          CampaignStatus @default(DRAFT)
  assets          CampaignAsset[]
  participants    CampaignParticipant[]
  submissions     Submission[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model CampaignAsset {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type       String   @default("IMAGE")
  url        String
  order      Int      @default(0)
}

model CampaignParticipant {
  id         String            @id @default(cuid())
  campaignId String
  campaign   Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatorId  String
  creator    User              @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  status     ParticipantStatus @default(ACTIVE)
  joinedAt   DateTime          @default(now())

  @@unique([campaignId, creatorId])
}

model Submission {
  id            String           @id @default(cuid())
  campaignId    String
  campaign      Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatorId     String
  creator       User             @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  videoUrl      String?
  thumbnailUrl  String?
  platformLink  String?
  platform      Platform?
  status        SubmissionStatus @default(PENDING)
  aiScore       Int?
  reviewNotes   String?
  submittedAt   DateTime         @default(now())
  reviewedAt    DateTime?
  viewLogs      ViewLog[]
}

model ViewLog {
  id            String     @id @default(cuid())
  submissionId  String
  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  views         Int
  date          DateTime   @default(now())
  isBotFiltered Boolean    @default(false)
  payoutAmount  Float?
}

model Payout {
  id           String       @id @default(cuid())
  creatorId    String
  creator      User         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  amount       Float
  status       PayoutStatus @default(PENDING)
  payoutMethod String
  accountInfo  String
  processedAt  DateTime?
  createdAt    DateTime     @default(now())
}

model Agency {
  id             String   @id @default(cuid())
  name           String
  ownerId        String   @unique
  owner          User     @relation("AgencyOwner", fields: [ownerId], references: [id])
  commissionRate Float    @default(10)
  totalEarnings  Float    @default(0)
  members        User[]   @relation("AgencyMembers")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model Transaction {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id])
  amount                Float
  status                String    @default("PENDING")
  midtransOrderId       String    @unique
  midtransTransactionId String?
  paymentMethod         String?
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}
